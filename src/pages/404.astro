---
import Base from '../layouts/Base.astro';
---

<Base title="Not found — Qualiber" description="This page could not be found." path="/404">
  <main class="notfound">
    <div class="code">404 · NO SIGNAL</div>
    <h1>That page isn't in the graph.</h1>
    <p class="body" style="margin-inline:auto;">The link may be old or mistyped. Let's get you back to solid ground.</p>
    <div class="cta-row" style="justify-content:center;">
      <a class="btn btn-primary" href="/">← Back to home</a>
    </div>
  </main>
</Base>
